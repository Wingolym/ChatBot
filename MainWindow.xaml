<Window x:Class="ChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatBot"
        mc:Ignorable="d"
        Title="AI ChatBot" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="450"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" x:Name="SidebarPanel" Background="#252538" BorderBrush="#3A3A50" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,0">
                    <Button x:Name="ToggleSidebarBtn" Width="32" Height="32" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="8,0" Click="ToggleSidebarBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="6">
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                          Fill="#D4854A" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A50"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="NewChatBtn" Content="+ Новый чат" Style="{StaticResource SidebarButtonStyle}"
                            Margin="4,0" Click="NewChatBtn_Click" Height="38"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatHistoryList" Margin="8"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#252538" BorderBrush="#3A3A50" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="OpenSidebarBtn" Width="32" Height="32" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="OpenSidebarBtn_Click" Margin="0,0,16,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="6">
                                    <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z"
                                          Fill="#D4854A" Width="20" Height="20" Stretch="Uniform"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A50"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#D4854A" Margin="0,0,12,0"/>
                        <TextBlock x:Name="ModelNameLabel" Text="AI ChatBot" Foreground="#E0D6CC" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chat Area -->
            <Border Grid.Row="1" Style="{StaticResource ChatBorderStyle}" Margin="20,16,20,8">
                <Grid>
                    <TextBlock x:Name="EmptyStateText" Text="Начните диалог..." Foreground="#5A5A70" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ScrollViewer x:Name="ChatScrollViewer" Style="{StaticResource ChatScrollViewerStyle}">
                        <StackPanel x:Name="ChatMessages" Margin="0,0,8,0"/>
                    </ScrollViewer>
                    <StackPanel x:Name="LoadingIndicator" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,16" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#8A8A9A" Margin="0,0,4,0">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Dot1" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Fill="#8A8A9A" Margin="0,0,4,0">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Dot2" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Fill="#8A8A9A">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Dot3" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Input Area -->
            <Border Grid.Row="2" Background="#252538" Padding="20,16" BorderBrush="#3A3A50" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="MessageInput" Style="{StaticResource ChatTextBoxStyle}"
                                 VerticalContentAlignment="Center" MaxHeight="120"
                                 PreviewKeyDown="MessageInput_PreviewKeyDown"/>
                    </Border>

                    <Button x:Name="SendButton" Grid.Column="1" Style="{StaticResource SendButtonStyle}" Margin="12,0,0,0"
                            Click="SendButton_Click">
                        <Path Data="M2,21 L23,12 L2,3 L2,10 L17,12 L2,14 Z" Fill="#1E1E2E" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>

                    <Button x:Name="SettingsButton" Grid.Column="2" Style="{StaticResource SettingsButtonStyle}"
                            Click="SettingsButton_Click">
                        <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" Fill="#D4854A" Width="22" Height="22" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>