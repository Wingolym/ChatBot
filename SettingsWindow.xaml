<Window x:Class="ChatBot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/icon.png">

    <Window.Resources>
        <Style x:Key="SettingsBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SettingsInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A50"/>
            <Setter Property="Foreground" Value="#E0D6CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#D4854A"/>
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3A3A50"/>
            <Setter Property="Foreground" Value="#E0D6CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#3A3A50"/>
                        <Setter Property="Foreground" Value="#E0D6CC"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#4A4A62"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#D4854A"/>
                                            <Setter Property="Foreground" Value="#1E1E2E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="2"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#3A3A50" CornerRadius="8">
                                            <Path x:Name="Arrow" Fill="#D4854A" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z" Margin="0,0,10,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="#E0D6CC"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Collapsed"
                                     Background="Transparent"
                                     Foreground="#E0D6CC"
                                     Padding="10,0,30,0"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                     BorderThickness="0"
                                     CaretBrush="#D4854A"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#3A3A50" CornerRadius="8" BorderBrush="#4A4A62" BorderThickness="1"/>
                                    <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4854A"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E89B65"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8703A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3A3A50"/>
            <Setter Property="Foreground" Value="#E0D6CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A62"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A2A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0D6CC"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A3A50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2F2F45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Connections List -->
        <Border Grid.Column="0" Style="{StaticResource SettingsBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Подключения" Foreground="#E0D6CC" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ListBox x:Name="ConnectionsList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource ConnectionItemStyle}"
                         SelectionChanged="ConnectionsList_SelectionChanged"
                         MouseDoubleClick="ConnectionsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" Foreground="#E0D6CC" FontSize="14"/>
                                    <TextBlock Text="{Binding Model}" Foreground="#8A8A9A" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Width="28" Height="28" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Удалить" Click="DeleteConnectionBtn_Click"
                                        Tag="{Binding Id}" Margin="4,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <Path Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z"
                                                      Fill="#8A8A9A" Width="14" Height="14" Stretch="Uniform"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#4A2020"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <Button x:Name="AddConnectionBtn" Content="+ Новое подключение" Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Stretch" Click="AddConnectionBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel - Connection Details / System Prompt -->
        <Border Grid.Column="2" Style="{StaticResource SettingsBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tab Headers -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton x:Name="TabConnection" Content="Подключение" Foreground="#D4854A" FontSize="14"
                                 IsChecked="True" GroupName="SettingsTabs" Margin="0,0,20,0" Checked="TabConnection_Checked"/>
                    <RadioButton x:Name="TabPrompt" Content="Системный промт" Foreground="#A0A0B8" FontSize="14"
                                 GroupName="SettingsTabs" Checked="TabPrompt_Checked"/>
                </StackPanel>

                <!-- Connection Editor -->
                <StackPanel x:Name="ConnectionEditor" Grid.Row="1" Visibility="Visible">
                    <TextBlock Text="Название" Style="{StaticResource SettingsLabelStyle}"/>
                    <TextBox x:Name="NameInput" Style="{StaticResource SettingsInputStyle}" Margin="0,0,0,16"/>

                    <TextBlock Text="Провайдер" Style="{StaticResource SettingsLabelStyle}"/>
                    <ComboBox x:Name="ProviderCombo" Style="{StaticResource SettingsComboBoxStyle}" Margin="0,0,0,16" SelectionChanged="ProviderCombo_SelectionChanged" Height="35">
                        <ComboBoxItem Content="OpenRouter"/>
                        <ComboBoxItem Content="LLM"/>
                    </ComboBox>

                    <TextBlock Text="API Key" Style="{StaticResource SettingsLabelStyle}"/>
                    <TextBox x:Name="ApiKeyInput" Style="{StaticResource SettingsInputStyle}" Margin="0,0,0,16"/>

                    <TextBlock Text="Модель" Style="{StaticResource SettingsLabelStyle}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ModelCombo" Style="{StaticResource SettingsComboBoxStyle}" IsEditable="True" Grid.ColumnSpan="2" Margin="0,0,8,0"/>
                        <Button x:Name="RefreshModelsBtn" Grid.Column="2" Content="↻" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,8" Click="RefreshModelsBtn_Click"/>
                    </Grid>

                    <TextBlock Text="Base URL (опционально)" Style="{StaticResource SettingsLabelStyle}"/>
                    <TextBox x:Name="BaseUrlInput" Style="{StaticResource SettingsInputStyle}" Margin="0,0,0,16"/>

                    <CheckBox x:Name="DefaultConnectionCheck" Content="Использовать по умолчанию" Foreground="#A0A0B8" FontSize="13" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- System Prompt Editor -->
                <StackPanel x:Name="PromptEditor" Grid.Row="1" Visibility="Collapsed">
                    <TextBlock Text="Системный промт определяет поведение AI-модели" Style="{StaticResource SettingsLabelStyle}" Margin="0,0,0,12"/>
                    <TextBox x:Name="SystemPromptInput" Style="{StaticResource SettingsInputStyle}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="200"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Bottom Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="DeleteBtn" Content="Удалить" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="DeleteBtn_Click"/>
                    <Button x:Name="SaveBtn" Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="SaveBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
